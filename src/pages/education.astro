---
import Layout from "../layouts/Layout.astro";
import PageHeader from "../components/PageHeader.astro";
import RoleTimeline from "../components/RoleTimeline.astro";
import { pagesById } from "../content/pages";
import { educations } from "../content/portfolio";

const meta = pagesById.education;

// Adapt education entries to the shape RoleTimeline expects
const educationRoles = educations.map((e) => ({
  title: e.school,
  org: e.degree,
  date: e.date,
  icon: e.icon,
  iconBg: e.iconBg,
  iconScale: e.iconScale,
  bullets: e.bullets,
}));
---

<Layout title="Education — Akishai" description={meta.blurb}>
  <PageHeader pageId="education" />

  <RoleTimeline label="Education" heading="Academic foundation" roles={educationRoles} />

  <div class="mx-auto max-w-4xl px-6 pb-32 text-center">
    <p class="font-mono text-xs uppercase tracking-[0.3em] text-silver-500">
      ◦ End of timeline ◦
    </p>
  </div>
</Layout>
