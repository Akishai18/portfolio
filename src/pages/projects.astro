---
import Layout from "../layouts/Layout.astro";
import PageHeader from "../components/PageHeader.astro";
import { pagesById } from "../content/pages";
import { projects } from "../content/portfolio";

const meta = pagesById.projects;
const featured = projects.filter((p) => p.featured);
const rest = projects.filter((p) => !p.featured);
---

<Layout title="Projects — Akishai" description={meta.blurb}>
  <PageHeader pageId="projects" />

  <section class="mx-auto max-w-7xl px-6 pb-32">
    {
      featured.length > 0 && (
        <div class="mb-20">
          {/* Section eyebrow — ties the cards back to the hero copy */}
          <header class="mb-6 flex items-baseline justify-between">
            <p class="font-mono text-[10px] uppercase tracking-[0.4em] text-gold-400">
              ◦ Featured
            </p>
            <span class="font-mono text-[10px] uppercase tracking-[0.3em] text-silver-500">
              {String(featured.length).padStart(2, "0")} · in flight
            </span>
          </header>

          <ul class="grid gap-8" role="list">
            {featured.map((p, i) => (
              <li
                class="group relative flex flex-col overflow-hidden rounded-2xl border border-silver-600/20 bg-void-900/40 backdrop-blur-sm transition-all duration-500 hover:border-gold-500/50 hover:shadow-[0_0_50px_rgba(184,134,11,0.18)] md:flex-row md:min-h-[380px]"
                style={`animation-delay: ${i * 80}ms`}
                data-fade-in
              >
                {/* Info column — left on desktop, top on mobile */}
                <div class="flex flex-col justify-between gap-6 p-7 md:w-2/5 md:shrink-0 md:p-10">
                  <div class="space-y-4">
                    <p class="font-mono text-[10px] uppercase tracking-[0.4em] text-gold-400/80">
                      <span class="text-gold-300">{String(i + 1).padStart(2, "0")}</span>
                      <span class="mx-2 text-silver-500">/</span>
                      Featured Build
                    </p>

                    <h3 class="text-3xl leading-[1.05] text-silver-100 md:text-4xl">
                      <a
                        href={p.link}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="transition-colors hover:text-gold-200"
                      >
                        {p.name}
                      </a>
                    </h3>

                    <p class="text-sm leading-relaxed text-silver-300/85 md:text-[15px]">
                      {p.description}
                    </p>
                  </div>

                  <div class="space-y-5">
                    <ul class="flex flex-wrap gap-2" role="list">
                      {p.tags.map((t) => (
                        <li class="rounded-full border border-gold-500/30 bg-gold-500/5 px-2.5 py-1 font-mono text-[10px] uppercase tracking-widest text-gold-300">
                          {t}
                        </li>
                      ))}
                    </ul>

                    <a
                      href={p.link}
                      target="_blank"
                      rel="noopener noreferrer"
                      data-magnetic
                      class="group/btn inline-flex items-center gap-2.5 rounded-full border border-gold-500/40 bg-gradient-to-b from-gold-500/10 to-transparent px-4 py-2 font-mono text-[10px] uppercase tracking-[0.3em] text-gold-200 transition hover:border-gold-400 hover:bg-gold-500/15 hover:shadow-[0_0_24px_rgba(184,134,11,0.25)]"
                    >
                      <span>Open project</span>
                      <svg
                        viewBox="0 0 16 16"
                        class="h-3 w-3 fill-none stroke-current transition-transform group-hover/btn:translate-x-0.5"
                        stroke-width="1.6"
                        aria-hidden="true"
                      >
                        <path
                          d="M3 8 H13 M9 4 L13 8 L9 12"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                        />
                      </svg>
                    </a>
                  </div>
                </div>

                {/* Preview column — stretches to match info column height on desktop */}
                <a
                  href={p.link}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={`Open ${p.name}`}
                  data-magnetic
                  class="relative block aspect-[16/10] overflow-hidden bg-void-800 md:aspect-auto md:flex-1 md:border-l md:border-silver-600/15"
                >
                  <img
                    src={p.image}
                    alt={p.name}
                    loading="lazy"
                    decoding="async"
                    class="h-full w-full object-cover object-top transition-transform duration-700 group-hover:scale-[1.03]"
                  />
                  {/* Soft gradient mask — fades the image edge so it bleeds into the card */}
                  <div
                    class="pointer-events-none absolute inset-y-0 left-0 w-32 bg-gradient-to-r from-void-950/85 via-void-950/35 to-transparent"
                    aria-hidden="true"
                  />
                  <div
                    class="pointer-events-none absolute inset-x-0 bottom-0 h-24 bg-gradient-to-t from-void-950/80 to-transparent"
                    aria-hidden="true"
                  />
                  {/* Gold halo on hover */}
                  <div
                    class="pointer-events-none absolute inset-0 opacity-0 transition-opacity duration-500 group-hover:opacity-100"
                    style="background: radial-gradient(circle at 60% 35%, rgba(184,134,11,0.20), transparent 60%);"
                    aria-hidden="true"
                  />
                </a>
              </li>
            ))}
          </ul>
        </div>
      )
    }

    {
      rest.length > 0 && (
        <div>
          <header class="mb-6 flex items-baseline justify-between">
            <p class="font-mono text-[10px] uppercase tracking-[0.4em] text-silver-300/80">
              ◦ More projects
            </p>
            <span class="font-mono text-[10px] uppercase tracking-[0.3em] text-silver-500">
              {String(rest.length).padStart(2, "0")}
            </span>
          </header>

          <ul class="grid gap-6 md:grid-cols-2 xl:grid-cols-3" role="list">
            {rest.map((p, i) => (
              <li
                class="group relative flex flex-col overflow-hidden rounded-2xl border border-silver-600/20 bg-void-900/40 backdrop-blur-sm transition-all duration-500 hover:border-gold-500/50 hover:shadow-[0_0_40px_rgba(184,134,11,0.15)]"
                style={`animation-delay: ${i * 60}ms`}
                data-fade-in
              >
                <a
                  href={p.link}
                  target="_blank"
                  rel="noopener noreferrer"
                  data-magnetic
                  class="relative block aspect-[16/10] overflow-hidden bg-void-800"
                  aria-label={`Open ${p.name}`}
                >
                  <img
                    src={p.image}
                    alt={p.name}
                    loading="lazy"
                    decoding="async"
                    class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
                  />
                  <div
                    class="pointer-events-none absolute inset-0 bg-gradient-to-t from-void-950 via-void-950/30 to-transparent"
                    aria-hidden="true"
                  />
                  <div
                    class="pointer-events-none absolute inset-0 opacity-0 transition-opacity duration-500 group-hover:opacity-100"
                    style="background: radial-gradient(circle at 50% 30%, rgba(184,134,11,0.18), transparent 60%);"
                    aria-hidden="true"
                  />
                </a>

                <div class="flex flex-1 flex-col gap-4 p-6">
                  <div class="flex items-start justify-between gap-4">
                    <h3 class="text-2xl text-silver-100">
                      <a
                        href={p.link}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="transition-colors hover:text-gold-300"
                      >
                        {p.name}
                      </a>
                    </h3>
                    <a
                      href={p.link}
                      target="_blank"
                      rel="noopener noreferrer"
                      data-magnetic
                      class="grid h-9 w-9 shrink-0 place-items-center rounded-full border border-silver-500/30 text-silver-300 transition hover:border-gold-400 hover:text-gold-300"
                      aria-label="Open project"
                    >
                      <svg
                        viewBox="0 0 24 24"
                        class="h-3.5 w-3.5 fill-none stroke-current"
                        stroke-width="2"
                      >
                        <path
                          d="M7 17 L17 7 M9 7 H17 V15"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                        />
                      </svg>
                    </a>
                  </div>

                  <p class="text-sm leading-relaxed text-silver-300/85">
                    {p.description}
                  </p>

                  <ul class="mt-auto flex flex-wrap gap-2 pt-2" role="list">
                    {p.tags.map((t) => (
                      <li class="rounded-full border border-gold-500/30 bg-gold-500/5 px-2.5 py-1 font-mono text-[10px] uppercase tracking-widest text-gold-300">
                        {t}
                      </li>
                    ))}
                  </ul>
                </div>
              </li>
            ))}
          </ul>
        </div>
      )
    }
  </section>
</Layout>

<style>
  [data-fade-in] {
    opacity: 0;
    transform: translateY(16px);
    animation: cardFade 700ms cubic-bezier(0.2, 0.7, 0.2, 1) forwards;
  }
  @keyframes cardFade {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    [data-fade-in] {
      opacity: 1;
      transform: none;
      animation: none;
    }
  }
</style>
