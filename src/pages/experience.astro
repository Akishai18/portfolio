---
import Layout from "../layouts/Layout.astro";
import PageHeader from "../components/PageHeader.astro";
import RoleTimeline from "../components/RoleTimeline.astro";
import { pagesById } from "../content/pages";
import { workExperience, leadership } from "../content/portfolio";

const meta = pagesById.experience;
---

<Layout title="Experience — Akishai" description={meta.blurb}>
  <PageHeader pageId="experience" />

  <RoleTimeline label="Work" heading="Engineering roles" roles={workExperience} />

  {/* Subtle divider */}
  <div class="mx-auto my-4 max-w-4xl px-6">
    <span class="block h-px w-full bg-gradient-to-r from-transparent via-gold-500/30 to-transparent"></span>
  </div>

  <RoleTimeline label="Leadership" heading="Building communities" roles={leadership} />

  <div class="mx-auto max-w-4xl px-6 pb-32 text-center">
    <p class="font-mono text-xs uppercase tracking-[0.3em] text-silver-500">
      ◦ End of timeline ◦
    </p>
  </div>
</Layout>
