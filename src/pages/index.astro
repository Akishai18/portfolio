---
import Layout from "../layouts/Layout.astro";
import SocialLinks from "../components/SocialLinks.astro";
import { profile } from "../content/profile";

const aboutCards = [
  {
    label: "Mission",
    body: "I'm a developer determined to push the boundaries of what's possible through technology. I believe many of the problems our world faces can be addressed with code — and I'm driven to build solutions that solve hard problems and make a difference.",
  },
  {
    label: "Focus",
    body: "Studying Software Engineering at the University of Waterloo. Alongside the technical work, I'm expanding into business and finance — and currently exploring machine learning and AI as a path into Quantitative Finance.",
  },
  {
    label: "How I work",
    body: "I love collaborative environments where I can use creativity to innovate and ship things that matter. I gravitate toward shared ownership, fast iteration, and ideas that make sense before they make money.",
  },
  {
    label: "Outside the code",
    body: "I lead student initiatives, run a tutoring business, and chase competitions across DECA, hackathons, and case comps. I'd rather be in the arena than at the sidelines.",
  },
];

// Split a fact body into plain + highlighted ({{ ... }}) segments
function parseFactBody(body: string): Array<{ text: string; hl: boolean }> {
  const parts: Array<{ text: string; hl: boolean }> = [];
  const re = /\{\{([^}]+)\}\}/g;
  let last = 0;
  let m: RegExpExecArray | null;
  while ((m = re.exec(body)) !== null) {
    if (m.index > last) parts.push({ text: body.slice(last, m.index), hl: false });
    parts.push({ text: m[1], hl: true });
    last = m.index + m[0].length;
  }
  if (last < body.length) parts.push({ text: body.slice(last), hl: false });
  return parts;
}
---

<Layout>
  <section class="relative mx-auto min-h-screen max-w-6xl px-6 pt-16 pb-24 md:pt-24">
    <!-- Eyebrow -->
    <p
      class="font-mono text-[10px] uppercase tracking-[0.5em] text-gold-400"
      data-fade-in
    >
      ◦ {profile.school} · {profile.program}
    </p>

    <!-- Two-column hero -->
    <div class="mt-10 grid items-start gap-14 md:grid-cols-[1.5fr_1fr] md:gap-16">
      <!-- Left: name + bio + links + jot notes -->
      <div>
        <h1
          class="text-balance text-6xl leading-[0.95] md:text-[7.5rem]"
          data-fade-in
          data-fade-in-delay="80"
        >
          <span class="block text-silver-200">Hello, I'm</span>
          <span
            class="text-gradient-gold mt-2 block italic"
            style="view-transition-name: hero-name;"
          >
            {profile.name}.
          </span>
        </h1>

        <p
          class="mt-8 max-w-xl text-pretty text-lg leading-[1.7] text-silver-300/90 md:text-xl"
          data-fade-in
          data-fade-in-delay="180"
        >
          {profile.tagline}
        </p>

        <!-- Jot notes — quick story arc -->
        <ul
          class="quick-facts mt-10"
          role="list"
          data-fade-in
          data-fade-in-delay="260"
        >
          {profile.quickFacts.map((row) => (
            <li class="quick-row">
              <div class="quick-head">
                <span class="quick-dot" aria-hidden="true"></span>
                <span class="quick-label">{row.label}</span>
                <span class="quick-rule" aria-hidden="true"></span>
              </div>
              <p class="quick-body">
                {parseFactBody(row.body).map((part) =>
                  part.hl ? <span class="hl">{part.text}</span> : part.text
                )}
              </p>
            </li>
          ))}
        </ul>

        <div class="mt-10" data-fade-in data-fade-in-delay="340">
          <SocialLinks />
        </div>
      </div>

      <!-- Right: portrait with gold ring -->
      <div class="relative mx-auto flex w-full max-w-md justify-center md:mt-6 md:justify-end">
        <div
          class="relative"
          data-fade-in
          data-fade-in-delay="120"
          style="view-transition-name: hero-photo;"
        >
          <!-- Outer glow -->
          <div
            class="pointer-events-none absolute -inset-6 rounded-full bg-gold-500/20 blur-3xl"
            aria-hidden="true"
          ></div>
          <!-- Rotating dashed ring -->
          <div
            class="pointer-events-none absolute -inset-3 rounded-full border border-dashed border-gold-500/40 animate-orbit"
            aria-hidden="true"
          ></div>
          <!-- Inner gold-tinted ring -->
          <div
            class="relative h-80 w-80 overflow-hidden rounded-full border border-gold-500/60 shadow-[0_0_40px_rgba(184,134,11,0.35),inset_0_0_30px_rgba(212,168,90,0.15)] md:h-96 md:w-96"
          >
            <img
              src={profile.photo}
              alt={profile.fullName}
              class="h-full w-full object-cover saturate-[0.85] contrast-[1.05]"
              loading="eager"
              decoding="async"
            />
            <!-- Soft black-gold vignette overlay -->
            <div
              class="absolute inset-0 bg-gradient-to-t from-void-950/70 via-transparent to-void-950/20 mix-blend-multiply"
              aria-hidden="true"
            ></div>
          </div>
          <!-- Tag underneath -->
          <p
            class="absolute -bottom-4 left-1/2 -translate-x-1/2 whitespace-nowrap rounded-full border border-gold-500/40 bg-void-900/90 px-3 py-1 font-mono text-[10px] uppercase tracking-[0.25em] text-gold-300 backdrop-blur-sm"
          >
            {profile.role}
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- About: intro + bio -->
  <section class="mx-auto max-w-3xl px-6 pt-12 pb-16 md:pt-20">
    <p
      class="font-mono text-[10px] uppercase tracking-[0.4em] text-gold-400"
      data-fade-in
    >
      ◦ About
    </p>
    <p
      class="mt-6 text-balance text-2xl leading-relaxed text-silver-200 md:text-3xl"
      data-fade-in
    >
      Hey, I'm <span class="text-gradient-gold italic">Akishai</span> — an
      ambitious Software Engineering student with a strong proclivity toward
      <span class="text-gold-300">programming</span>,
      <span class="text-gold-300">engineering</span>, and
      <span class="text-gold-300">finance</span>.
    </p>
    <p
      class="mt-6 text-pretty text-base leading-relaxed text-silver-300/85 md:text-lg"
      data-fade-in
    >
      {profile.shortBio}
    </p>
  </section>

  <!-- About cards -->
  <section class="mx-auto max-w-5xl px-6 pb-20">
    <ul class="grid gap-5 md:grid-cols-2" role="list">
      {
        aboutCards.map((c, i) => (
          <li
            class="about-card group relative overflow-hidden rounded-2xl border border-silver-600/20 bg-void-900/40 p-6 backdrop-blur-sm transition-all duration-300 hover:border-gold-500/40 hover:bg-void-900/60 md:p-8"
            style={`animation-delay: ${i * 80}ms`}
          >
            <div
              class="pointer-events-none absolute -top-16 -right-16 h-44 w-44 rounded-full opacity-0 blur-3xl transition-opacity duration-500 group-hover:opacity-50"
              style="background: radial-gradient(circle, rgba(184,134,11,0.5), transparent 70%);"
              aria-hidden="true"
            />
            <p class="relative font-mono text-[10px] uppercase tracking-[0.4em] text-gold-400">
              ◦ {c.label}
            </p>
            <p class="relative mt-4 text-base leading-relaxed text-silver-200/95 md:text-lg">
              {c.body}
            </p>
          </li>
        ))
      }
    </ul>
  </section>

  <!-- Currently building -->
  <section class="mx-auto max-w-3xl px-6 pb-32">
    <header class="mb-6">
      <p class="font-mono text-[10px] uppercase tracking-[0.4em] text-gold-400">
        ◦ Currently building
      </p>
      <h2 class="mt-2 text-3xl md:text-4xl">
        <span class="text-gradient-silver">In flight</span>
        <span class="text-gradient-gold italic">.</span>
      </h2>
    </header>
    <ul class="space-y-4" role="list">
      {
        profile.currentlyBuilding.map((item, i) => (
          <li class="flex gap-4 rounded-xl border border-silver-600/20 bg-void-900/30 p-5">
            <span class="font-mono text-xs text-gold-400 tabular-nums">
              {String(i + 1).padStart(2, "0")}
            </span>
            <p class="leading-relaxed text-silver-300/90">{item}</p>
          </li>
        ))
      }
    </ul>
  </section>
</Layout>

<style>
  /* Subtle staggered entrance for [data-fade-in] elements */
  [data-fade-in] {
    opacity: 0;
    transform: translateY(14px);
    animation: fadeInUp 800ms cubic-bezier(0.2, 0.7, 0.2, 1) forwards;
    animation-delay: var(--fade-delay, 0ms);
  }
  @keyframes fadeInUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes orbit {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }
  .animate-orbit {
    animation: orbit 24s linear infinite;
  }

  /* About card entrance — fades in via animation-delay (set inline per card) */
  .about-card {
    opacity: 0;
    transform: translateY(14px);
    animation: fadeInUp 700ms cubic-bezier(0.2, 0.7, 0.2, 1) forwards;
  }

  /* --- Quick facts (jot notes) --- */
  .quick-facts {
    max-width: 720px;
    display: flex;
    flex-direction: column;
    gap: 1.4rem;
  }
  .quick-row {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .quick-head {
    display: flex;
    align-items: center;
    gap: 0.7rem;
  }
  .quick-dot {
    width: 6px;
    height: 6px;
    border-radius: 9999px;
    background: linear-gradient(135deg, #e6c275, #b8860b);
    box-shadow: 0 0 8px rgba(184, 134, 11, 0.65);
    flex-shrink: 0;
  }
  .quick-label {
    font-family: "Geist Mono", ui-monospace, monospace;
    font-size: 12px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.32em;
    color: #d4a85a;
    flex-shrink: 0;
    /* lift the visual a bit since uppercase mono sits low in its line-box */
    line-height: 1;
  }
  .quick-rule {
    flex: 1;
    height: 1px;
    background: linear-gradient(
      to right,
      rgba(212, 168, 90, 0.28) 0%,
      rgba(212, 168, 90, 0.08) 50%,
      rgba(212, 168, 90, 0) 100%
    );
  }
  .quick-arrow {
    display: none;
  }
  .quick-body {
    margin: 0;
    font-size: 16px;
    line-height: 1.65;
    color: rgba(216, 219, 226, 0.92);
  }
  /* Inline highlight pills for key terms */
  .hl {
    display: inline-block;
    padding: 0.05em 0.55em;
    background: rgba(212, 168, 90, 0.1);
    border: 1px solid rgba(184, 134, 11, 0.32);
    border-radius: 5px;
    color: #e6c275;
    font-weight: 500;
    line-height: 1.45;
    white-space: nowrap;
    transition: background-color 200ms ease, border-color 200ms ease;
  }
  .hl:hover,
  .quick-row:hover .hl {
    background: rgba(212, 168, 90, 0.18);
    border-color: rgba(212, 168, 90, 0.55);
  }

  @media (prefers-reduced-motion: reduce) {
    [data-fade-in],
    .about-card {
      opacity: 1;
      transform: none;
      animation: none;
    }
    .animate-orbit {
      animation: none;
    }
  }
</style>

<script>
  // Apply per-element fade-in delays from data-attr
  document.querySelectorAll<HTMLElement>("[data-fade-in-delay]").forEach((el) => {
    const d = el.getAttribute("data-fade-in-delay");
    if (d) el.style.setProperty("--fade-delay", `${d}ms`);
  });
</script>
