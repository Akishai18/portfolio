---
import { pages } from "../content/pages";
import Planet from "./Planet.astro";

const path = Astro.url.pathname.replace(/\/$/, "") || "/";

// All canonical paths that should be navigable
const isHome = path === "/";
---

<aside
  class="nav-rail pointer-events-none fixed inset-y-0 left-0 z-40 hidden w-[210px] flex-col justify-between px-7 py-8 md:flex"
  aria-label="Primary navigation"
>
  {/* Brand / home */}
  <div class="pointer-events-auto">
    <a
      href="/"
      data-magnetic
      aria-current={isHome ? "page" : undefined}
      class:list={[
        "group flex items-center gap-3 transition",
        isHome ? "text-gold-200" : "text-silver-200 hover:text-gold-300",
      ]}
    >
      {/* Sun glyph */}
      <span
        class="relative grid h-6 w-6 shrink-0 place-items-center"
        aria-hidden="true"
      >
        <span
          class="absolute inset-0 rounded-full bg-gradient-to-br from-gold-300 via-gold-500 to-gold-700 shadow-[0_0_10px_rgba(184,134,11,0.7)] transition group-hover:shadow-[0_0_18px_rgba(184,134,11,0.9)]"
        ></span>
        <span class="absolute inset-0 rounded-full ring-1 ring-gold-500/40"></span>
      </span>
      <span
        class="font-display text-base italic tracking-[0.02em] transition"
        style="view-transition-name: brand-name;"
      >
        Akishai
      </span>
    </a>
  </div>

  {/* Page links — vertical, lowercase, sparse */}
  <nav class="pointer-events-auto" aria-label="Pages">
    <ul class="flex flex-col gap-7" role="list">
      {
        pages.map((p) => {
          const active = path === p.href;
          return (
            <li>
              <a
                href={p.href}
                data-magnetic
                aria-current={active ? "page" : undefined}
                class:list={[
                  "rail-link group relative flex items-center gap-3.5 font-display text-2xl tracking-[0.01em]",
                  active ? "is-active text-gold-200" : "text-silver-300/70 hover:text-silver-100",
                ]}
              >
                {/* Planet glyph — surface treatment per kind, dashed orbit
                    ring fades in when the page is active. */}
                <span
                  class:list={[
                    "rail-planet relative grid shrink-0 place-items-center",
                  ]}
                  style={`view-transition-name: rail-planet-${p.id};`}
                  aria-hidden="true"
                >
                  <Planet
                    pageId={p.id}
                    size={18}
                    active={active}
                    class="rail-planet-glyph"
                  />
                  <span
                    class="rail-planet-ring absolute -inset-[4px] rounded-full"
                    style={`border: 1px dashed ${p.accent}80;`}
                  ></span>
                </span>

                {/* Title with animated underline */}
                <span class="rail-title relative lowercase">
                  {p.title}
                  <span class="rail-underline" aria-hidden="true"></span>
                </span>

                {/* Hover/active chevron — slides in from the left */}
                <span
                  class="rail-chevron font-mono text-xs text-gold-300"
                  aria-hidden="true"
                >→</span>
              </a>
            </li>
          );
        })
      }
    </ul>
  </nav>

  {/* Webring icons — community badges */}
  <div class="pointer-events-auto">
    <p
      class="mb-3 font-mono text-[8px] uppercase tracking-[0.4em] text-silver-500"
    >
      ◦ Webrings
    </p>
    <ul class="flex flex-wrap items-center gap-2.5" role="list">
      {/* SE '30 Webring — prev / icon / next */}
      <li class="flex items-center gap-1.5">
        <a
          href="https://se30webring.com?from=https://akishai.dev&dir=prev"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Previous in SE '30 Webring"
          data-magnetic
          class="text-gold-400/70 transition hover:text-gold-200"
        >
          <svg viewBox="0 0 16 16" class="h-3 w-3 fill-current" aria-hidden="true">
            <path d="M11 2 L4 8 L11 14 L11 2 Z" />
          </svg>
        </a>
        <a
          href="https://se30webring.com"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="SE '30 Webring"
          data-magnetic
          class="block transition-transform hover:scale-110"
          title="SE '30 Webring"
        >
          <img
            src="https://se30webring.com/assets/icon-yellow.svg"
            alt="SE '30 Webring"
            class="h-7 w-7 opacity-80 transition-opacity hover:opacity-100"
            loading="lazy"
            decoding="async"
          />
        </a>
        <a
          href="https://se30webring.com?from=https://akishai.dev&dir=next"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Next in SE '30 Webring"
          data-magnetic
          class="text-gold-400/70 transition hover:text-gold-200"
        >
          <svg viewBox="0 0 16 16" class="h-3 w-3 fill-current" aria-hidden="true">
            <path d="M5 2 L12 8 L5 14 L5 2 Z" />
          </svg>
        </a>
      </li>

      {/* UW SE Webring */}
      <li>
        <a
          href="https://se-webring.xyz"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="UW SE Webring"
          data-magnetic
          class="block transition-transform hover:scale-110"
          title="UW SE Webring"
        >
          <img
            src="/img/webring.png"
            alt="UW SE Webring"
            class="h-7 w-7 object-contain opacity-80 transition-opacity hover:opacity-100"
            loading="lazy"
            decoding="async"
          />
        </a>
      </li>
    </ul>
  </div>
</aside>

{/* Mobile fallback: bottom dock with planet glyphs only */}
<header
  class="fixed inset-x-0 bottom-0 z-40 flex justify-center md:hidden pointer-events-none"
  aria-label="Primary"
>
  <nav
    class="pointer-events-auto mb-4 flex items-center gap-1 rounded-full border border-silver-600/25 bg-void-900/80 px-2 py-2 backdrop-blur-xl shadow-[0_8px_40px_rgba(0,0,0,0.5)]"
  >
    <a
      href="/"
      data-magnetic
      aria-current={isHome ? "page" : undefined}
      class:list={[
        "grid h-8 w-8 place-items-center rounded-full transition",
        isHome ? "bg-gold-500/15" : "hover:bg-silver-100/5",
      ]}
      aria-label="Home"
    >
      <span class="relative h-3.5 w-3.5">
        <span
          class="absolute inset-0 rounded-full bg-gradient-to-br from-gold-300 via-gold-500 to-gold-700 shadow-[0_0_8px_rgba(184,134,11,0.7)]"
        ></span>
      </span>
    </a>
    <span class="mx-1 h-5 w-px bg-silver-500/20" aria-hidden="true"></span>
    {
      pages.map((p) => {
        const active = path === p.href;
        return (
          <a
            href={p.href}
            data-magnetic
            aria-label={p.title}
            aria-current={active ? "page" : undefined}
            class:list={[
              "grid h-8 w-8 place-items-center rounded-full transition",
              active ? "bg-gold-500/15" : "hover:bg-silver-100/5",
            ]}
          >
            <Planet pageId={p.id} size={14} active={active} />
          </a>
        );
      })
    }
  </nav>
</header>

<style>
  /* --- Page links ---------------------------------------------------- */
  .rail-link {
    transition: color 220ms ease;
  }

  /* Title slides ~4px right on hover so the row feels responsive */
  .rail-title {
    display: inline-block;
    transition: transform 280ms cubic-bezier(0.2, 0.7, 0.2, 1);
  }
  .rail-link:hover .rail-title {
    transform: translateX(4px);
  }
  .rail-link.is-active {
    font-style: italic;
  }

  /* Animated gold underline beneath the title — grows from left on hover,
     stays at full width when the page is active. */
  .rail-underline {
    position: absolute;
    left: 0;
    bottom: -3px;
    height: 1px;
    width: 0;
    background: linear-gradient(
      to right,
      rgba(212, 168, 90, 0.9) 0%,
      rgba(212, 168, 90, 0.4) 70%,
      rgba(212, 168, 90, 0) 100%
    );
    transition: width 320ms cubic-bezier(0.2, 0.7, 0.2, 1);
  }
  .rail-link:hover .rail-underline {
    width: 60%;
  }
  .rail-link.is-active .rail-underline {
    width: 100%;
  }

  /* Right-side chevron that slides in on hover or active */
  .rail-chevron {
    opacity: 0;
    transform: translateX(-6px);
    transition:
      opacity 240ms ease,
      transform 280ms cubic-bezier(0.2, 0.7, 0.2, 1);
  }
  .rail-link:hover .rail-chevron,
  .rail-link.is-active .rail-chevron {
    opacity: 1;
    transform: translateX(0);
  }

  /* Planet glyph subtly grows on hover and a touch more when active.
     Scaling the whole glyph (not just an orb) so the layered surface
     and atmosphere scale together. */
  :global(.rail-planet-glyph) {
    transition: transform 260ms cubic-bezier(0.2, 0.7, 0.2, 1);
  }
  .rail-link:hover :global(.rail-planet-glyph) {
    transform: scale(1.12);
  }
  .rail-link.is-active :global(.rail-planet-glyph) {
    transform: scale(1.18);
  }

  /* Selection orbit — dashed circle slowly rotating around the active item */
  .rail-planet-ring {
    opacity: 0;
    transform: scale(0.7) rotate(0deg);
    transition:
      opacity 320ms ease,
      transform 360ms cubic-bezier(0.2, 0.7, 0.2, 1);
  }
  .rail-link.is-active .rail-planet-ring {
    opacity: 1;
    transform: scale(1) rotate(0deg);
    animation: rail-orbit 16s linear infinite;
  }
  @keyframes rail-orbit {
    from { transform: scale(1) rotate(0deg); }
    to   { transform: scale(1) rotate(360deg); }
  }

  @media (prefers-reduced-motion: reduce) {
    .rail-title,
    .rail-underline,
    .rail-chevron,
    :global(.rail-planet-glyph),
    .rail-planet-ring {
      transition: none;
      animation: none;
    }
  }
</style>
