---

<ul class:list={["flex flex-wrap items-center gap-3", className]} role="list">
  {
    items.map((it) => (
      <li>
        <a
          href={it.href}
          target={it.href.startsWith("mailto") ? undefined : "_blank"}
          rel={it.href.startsWith("mailto") ? undefined : "noopener noreferrer"}
          aria-label={it.name}
          class:list={[
            "group relative grid place-items-center rounded-full border border-silver-500/25 bg-void-900/40 text-silver-300 backdrop-blur-sm transition-all duration-300 hover:border-gold-400/70 hover:bg-gold-500/10 hover:text-gold-300",
            dim,
          ]}
          data-magnetic
        >
          <svg viewBox="0 0 24 24" class:list={["fill-current", icon]} aria-hidden="true">
            <path d={it.path} />
          </svg>
          <span
            class="pointer-events-none absolute -bottom-7 left-1/2 -translate-x-1/2 whitespace-nowrap rounded-full bg-void-800/90 px-2 py-0.5 font-mono text-[9px] uppercase tracking-widest text-silver-300 opacity-0 transition-opacity group-hover:opacity-100"
          >
            {it.name}
          </span>
        </a>
      </li>
    ))
  }
</ul>
