---
import { profile } from "../content/profile";

interface Props {
  size?: "sm" | "md";
  class?: string;
}

const { size = "md", class: className = "" } = Astro.props;
const dim = size === "sm" ? "h-9 w-9" : "h-11 w-11";
const icon = size === "sm" ? "h-4 w-4" : "h-5 w-5";

const items = [
  {
    name: "GitHub",
