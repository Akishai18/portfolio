    path: "M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8l-6-6Zm0 1.5L18.5 8H14V3.5ZM7.5 11.5h9v1.5h-9v-1.5Zm0 4h9V17h-9v-1.5Zm0 4h6V21h-6v-1.5Z",
  },
  {
    name: "Twitter / X",
