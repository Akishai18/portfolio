---
import "../styles/global.css";
import Starfield from "../components/Starfield.astro";
import Cursor from "../components/Cursor";
import NavRail from "../components/NavRail.astro";
import { ClientRouter } from "astro:transitions";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Akishai — Software Engineer",
  description = "Personal portfolio of Akishai — Software Engineering @ University of Waterloo. Builder, engineer, problem-solver.",
} = Astro.props;
---

<!doctype html>
<html lang="en" class="has-custom-cursor">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#050608" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body>
    <a href="#main" class="skip-to-content">Skip to content</a>
    <Starfield transition:persist transition:name="starfield-layer" />
    <Cursor client:load transition:persist transition:name="cursor-layer" />
    <NavRail />
    <main id="main" class="relative z-10 min-h-screen md:pl-[180px]">
      <slot />
    </main>
  </body>
</html>
