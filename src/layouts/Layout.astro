---
import "../styles/global.css";
import Starfield from "../components/Starfield.astro";
import Cursor from "../components/Cursor";
import NavRail from "../components/NavRail.astro";
import { ClientRouter } from "astro:transitions";

interface Props {
  title?: string;
  description?: string;
  /** Path to a square or 1200x630 share image, served from /public. */
  image?: string;
  /**
   * Override the page type for og:type. Default `website`; use `article`
   * for any future blog posts so they get richer LinkedIn/X previews.
   */
  ogType?: "website" | "article" | "profile";
}

const {
  title = "Akishai — Software Engineer",
  description = "Personal portfolio of Akishai Sabaratnasarma — Software Engineering @ University of Waterloo. Builder, engineer, problem-solver working at the intersection of ML, full-stack systems, and quantitative finance.",
  image = "/img/me.jpg",
  ogType = "website",
} = Astro.props;

// `Astro.site` comes from the `site` field in astro.config.mjs and is the
// canonical absolute base URL. Build canonical + absolute share URLs from
// it so previews on Twitter/LinkedIn/Slack actually load the image.
const site = Astro.site ?? new URL("https://akishai.com");
const canonicalURL = new URL(Astro.url.pathname, site).toString();
const absoluteImage = new URL(image, site).toString();

// Person schema — tells Google "this is a personal site about a real
// person", powers the knowledge-panel-style result if you ever build
// up enough authority signals.
const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Akishai Sabaratnasarma",
  alternateName: "Akishai",
  url: site.toString(),
  image: new URL("/img/me.jpg", site).toString(),
  jobTitle: "Software Engineer",
  description,
  alumniOf: {
    "@type": "CollegeOrUniversity",
    name: "University of Waterloo",
  },
  sameAs: [
    "https://github.com/Akishai18",
    "https://www.linkedin.com/in/akishai",
    "https://x.com/Akishai_S",
  ],
};
---

<!doctype html>
<html lang="en" class="has-custom-cursor">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/favicon-me.png" />
    <link rel="apple-touch-icon" href="/favicon-me.png" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#050608" />

    {/* Primary SEO */}
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Akishai Sabaratnasarma" />
    <meta name="keywords" content="Akishai, Akishai Sabaratnasarma, software engineer, University of Waterloo, machine learning, quantitative finance, full-stack, portfolio" />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1" />
    <link rel="canonical" href={canonicalURL} />

    {/* Open Graph — share previews on LinkedIn, Slack, Discord, Facebook */}
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Akishai" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={absoluteImage} />
    <meta property="og:image:alt" content="Akishai Sabaratnasarma" />
    <meta property="og:locale" content="en_US" />

    {/* Twitter / X card */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteImage} />
    <meta name="twitter:creator" content="@Akishai_S" />
    <meta name="twitter:site" content="@Akishai_S" />

    {/* Structured data — Person schema, helps Google understand who the
        site is about and connects social profiles together. */}
    <script type="application/ld+json" is:inline set:html={JSON.stringify(personSchema)} />

    <ClientRouter />
  </head>
  <body>
    <a href="#main" class="skip-to-content">Skip to content</a>
    <Starfield transition:persist transition:name="starfield-layer" />
    <Cursor client:load transition:persist transition:name="cursor-layer" />
    <NavRail />
    <main id="main" class="relative z-10 min-h-screen md:pl-[180px]">
      <slot />
    </main>

    {/* Home-page audio — plays every time the home route is opened.
        transition:persist keeps the element alive across view transitions
        so playback isn't interrupted mid-stream. */}
    <audio
      id="home-audio"
      src="/audio/intro.mp3"
      preload="auto"
      transition:persist
    ></audio>

    <script>
      (function () {
        // ── Audio toggle ────────────────────────────────────────────────
        // Flip this to false to disable home-page audio entirely.
        const ENABLED = false;
        // ────────────────────────────────────────────────────────────────

        // Play the first ~5s at full volume, then fade out over 1s.
        const HOLD_MS = 5000;
        const FADE_MS = 1000;
        const STEP_MS = 40;

        if (!ENABLED) return;

        let holdTimer: number | null = null;
        let fadeTimer: number | null = null;

        function clearTimers() {
          if (holdTimer !== null) {
            window.clearTimeout(holdTimer);
            holdTimer = null;
          }
          if (fadeTimer !== null) {
            window.clearInterval(fadeTimer);
            fadeTimer = null;
          }
        }

        function isHome() {
          const p = window.location.pathname;
          return p === "/" || p === "";
        }

        function getAudio() {
          return document.getElementById(
            "home-audio",
          ) as HTMLAudioElement | null;
        }

        function startFade() {
          const audio = getAudio();
          if (!audio) return;
          const steps = Math.max(1, Math.floor(FADE_MS / STEP_MS));
          const startVol = audio.volume;
          let step = 0;
          fadeTimer = window.setInterval(() => {
            step++;
            audio.volume = Math.max(0, startVol * (1 - step / steps));
            if (step >= steps) {
              clearTimers();
              audio.pause();
              try {
                audio.currentTime = 0;
              } catch {}
              audio.volume = 1;
            }
          }, STEP_MS);
        }

        function scheduleFade() {
          holdTimer = window.setTimeout(startFade, HOLD_MS);
        }

        function play() {
          const audio = getAudio();
          if (!audio) return;

          clearTimers();
          audio.volume = 1;
          try {
            audio.currentTime = 0;
          } catch {}

          const p = audio.play();
          if (p && typeof p.then === "function") {
            p.then(scheduleFade).catch(() => {
              // Autoplay blocked — retry once on first user interaction.
              const unlock = () => {
                window.removeEventListener("pointerdown", unlock);
                window.removeEventListener("keydown", unlock);
                window.removeEventListener("touchstart", unlock);
                if (!isHome()) return;
                clearTimers();
                audio.volume = 1;
                try {
                  audio.currentTime = 0;
                } catch {}
                audio.play().then(scheduleFade).catch(() => {});
              };
              window.addEventListener("pointerdown", unlock, { once: true });
              window.addEventListener("keydown", unlock, { once: true });
              window.addEventListener("touchstart", unlock, { once: true });
            });
          } else {
            scheduleFade();
          }
        }

        function stop() {
          const audio = getAudio();
          clearTimers();
          if (!audio) return;
          if (!audio.paused) {
            audio.pause();
            try {
              audio.currentTime = 0;
            } catch {}
          }
          audio.volume = 1;
        }

        function handlePageLoad() {
          if (isHome()) play();
          else stop();
        }

        document.addEventListener("astro:page-load", handlePageLoad);
      })();
    </script>
  </body>
</html>
